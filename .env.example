# Pro-Fab 3D — Environment Variables Template
# Copy this file to .env and fill in your values for local development.
# Production values should be set in Netlify → Site → Environment Variables.

# ── Database connection (MySQL) ───────────────────────────────────────────────
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=pro-fab-3d
DB_USERNAME=root
DB_PASSWORD=

# ── Admin credentials ─────────────────────────────────────────────────────────
ADMIN_SALT=
ADMIN_HASH=

# ── Stripe ───────────────────────────────────────────────────────────────────
STRIPE_PUBLISHABLE_KEY=
STRIPE_SECRET_KEY=sk_test_
